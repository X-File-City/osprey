{
  "id": "osprey-onboarding",
  "title": "Osprey Compiler Onboarding",
  "description": "Guided walkthrough of the Osprey language compiler: a functional language with algebraic effects, fiber concurrency, and LLVM codegen.",
  "version": "1.0.0",
  "audience": "New Contributors",
  "prerequisites": [
    "Familiarity with Go and compiler basics",
    "Optional: exposure to LLVM IR and ANTLR"
  ],
  "steps": [
    {
      "id": "step-1-repo-overview",
      "title": "Repository Overview",
      "description": "Osprey is a multi-package monorepo. The core compiler sits alongside surrounding tooling for editor support, documentation, browser-based compilation, and distribution.",
      "estimatedTime": 60,
      "focusDirectory": "",
      "colorMode": "fileTypes"
    },
    {
      "id": "step-2-compiler-entry",
      "title": "Compiler Entry Point",
      "description": "The Osprey CLI entry point wires up the full pipeline: parse the source, build an AST, infer types, emit LLVM IR, then either JIT or produce a binary. A top-level build script orchestrates build, test, and install.",
      "estimatedTime": 90,
      "focusDirectory": "compiler/cmd",
      "highlightLayers": [
        {
          "id": "entry-and-build",
          "name": "CLI Entry",
          "color": "#10b981",
          "items": [
            { "path": "compiler/cmd", "type": "directory" }
          ],
          "opacity": 0.75,
          "renderStrategy": "border"
        }
      ],
      "colorMode": "fileTypes"
    },
    {
      "id": "step-3-grammar-and-parser",
      "title": "Grammar & Parser",
      "description": "Osprey's syntax is defined by an ANTLR4 grammar. Generated parser sources sit alongside the grammar, and grammar changes flow through a dedicated regeneration step before the rest of the pipeline sees them.",
      "estimatedTime": 90,
      "focusDirectory": "compiler/parser",
      "highlightLayers": [
        {
          "id": "frontend-grammar",
          "name": "Generated Parser",
          "color": "#a855f7",
          "items": [
            { "path": "compiler/parser", "type": "directory" }
          ],
          "opacity": 0.7,
          "renderStrategy": "border"
        }
      ],
      "colorMode": "fileTypes"
    },
    {
      "id": "step-4-ast-builders",
      "title": "AST Construction",
      "description": "This stage converts parse trees into a typed AST. Builders are split by language construct — literals, calls, match expressions, fibers, interpolation, and statements — and a dedicated validation pass enforces structural rules before anything reaches codegen.",
      "estimatedTime": 120,
      "focusDirectory": "compiler/internal/ast",
      "highlightLayers": [
        {
          "id": "ast-core",
          "name": "AST Core & Validation",
          "color": "#f59e0b",
          "items": [
            { "path": "compiler/internal/ast/ast.go", "type": "file" },
            { "path": "compiler/internal/ast/validation.go", "type": "file" },
            { "path": "compiler/internal/ast/builder_core.go", "type": "file" }
          ],
          "opacity": 0.75,
          "renderStrategy": "border"
        },
        {
          "id": "ast-builders",
          "name": "Construct Builders",
          "color": "#ec4899",
          "items": [
            { "path": "compiler/internal/ast/builder_match.go", "type": "file" },
            { "path": "compiler/internal/ast/builder_fibers.go", "type": "file" },
            { "path": "compiler/internal/ast/builder_interpolation.go", "type": "file" },
            { "path": "compiler/internal/ast/builder_calls.go", "type": "file" }
          ],
          "opacity": 0.65,
          "renderStrategy": "border"
        }
